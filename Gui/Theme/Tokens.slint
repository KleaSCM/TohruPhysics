// Tokens — TohruPhysics GUI design system tokens.
// TohruPhysics GUI デザインシステムトークンね。
//
// Single source of truth for all visual properties: colours, spacing,
// typography, border-radius, shadow, and animation durations.
// Dark mode is the default; ThemeMode = 1 switches to light.
//
// USAGE:
//   import { Tokens } from "Tokens.slint";
//   background: Tokens.SurfacePrimary;

import { Palette } from "std-widgets.slint";

export global Tokens {
	/* ------------------------------------------------------------------
	 *  Theme mode
	 *  テーマモードね。
	 * ---------------------------------------------------------------- */
	in-out property <int> ThemeMode: 0; /* 0=dark 1=light 2=custom      */

	/* ------------------------------------------------------------------
	 *  Colour palette — dark mode (§3.28)
	 *  カラーパレット — ダークモードね。
	 * ---------------------------------------------------------------- */
	out property <color> SurfacePrimary:   ThemeMode == 0 ? #141417 : #F2F2F7;
	out property <color> SurfaceSecondary: ThemeMode == 0 ? #1C1C20 : #E8E8EE;
	out property <color> SurfaceTertiary:  ThemeMode == 0 ? #242428 : #DCDCE6;
	out property <color> SurfaceElevated:  ThemeMode == 0 ? #2A2A30 : #FFFFFF;
	out property <color> SurfaceBorder:    ThemeMode == 0 ? #38383F : #C8C8D0;
	out property <color> SurfaceOverlay:   ThemeMode == 0 ? #00000088 : #00000040;

	/* Accent — violet-blue physics energy */
	out property <color> AccentPrimary:    ThemeMode == 0 ? #6B8FFF : #3A62E0;
	out property <color> AccentHover:      ThemeMode == 0 ? #879FFF : #5577F0;
	out property <color> AccentPressed:    ThemeMode == 0 ? #5577E0 : #2850C8;
	out property <color> AccentSubtle:     ThemeMode == 0 ? #6B8FFF28 : #3A62E020;

	/* Text */
	out property <color> TextPrimary:      ThemeMode == 0 ? #F0F0F4 : #0A0A0E;
	out property <color> TextSecondary:    ThemeMode == 0 ? #9090A0 : #60607A;
	out property <color> TextMuted:        ThemeMode == 0 ? #606070 : #9090A8;
	out property <color> TextOnAccent:     #FFFFFF;

	/* Status */
	out property <color> StatusSuccess:    ThemeMode == 0 ? #4ADE80 : #16A34A;
	out property <color> StatusWarning:    ThemeMode == 0 ? #FBBF24 : #D97706;
	out property <color> StatusError:      ThemeMode == 0 ? #F87171 : #DC2626;
	out property <color> StatusInfo:       ThemeMode == 0 ? #60A5FA : #2563EB;

	/* Physics debug colours */
	out property <color> DebugContact:     #FF4060;
	out property <color> DebugVelocity:    #40FF80;
	out property <color> DebugAngVel:      #FF8040;
	out property <color> DebugAABB:        #40C0FF;
	out property <color> DebugBVH:         #C040FF;
	out property <color> DebugSleeping:    #6060C0;
	out property <color> DebugActive:      #40FF40;
	out property <color> DebugJoint:       #FFFF40;

	/* Demo category badge colours */
	out property <color> CatRigid:         #6B8FFF;
	out property <color> CatSoft:          #A87FFF;
	out property <color> CatFluid:         #40C8FF;
	out property <color> CatParticles:     #FF8040;
	out property <color> CatConstraints:   #40FF80;
	out property <color> CatDestruction:   #FF4060;
	out property <color> CatVehicle:       #FFCC40;
	out property <color> CatCharacter:     #FF80C0;
	out property <color> CatScience:       #80FFCC;
	out property <color> CatGame:          #FF6080;
	out property <color> CatMulti:         #C0C0FF;

	/* ------------------------------------------------------------------
	 *  Typography (§3.28)
	 *  タイポグラフィね。
	 * ---------------------------------------------------------------- */
	out property <length> FontSizeTiny:   10px;
	out property <length> FontSizeSmall:  11px;
	out property <length> FontSizeBody:   13px;
	out property <length> FontSizeMedium: 14px;
	out property <length> FontSizeLarge:  16px;
	out property <length> FontSizeTitle:  20px;
	out property <length> FontSizeHero:   28px;

	/* ------------------------------------------------------------------
	 *  Spacing
	 *  スペーシングね。
	 * ---------------------------------------------------------------- */
	out property <length> SpaceXS:   3px;
	out property <length> SpaceSM:   6px;
	out property <length> SpaceMD:  10px;
	out property <length> SpaceLG:  16px;
	out property <length> SpaceXL:  24px;
	out property <length> SpaceXXL: 36px;

	/* ------------------------------------------------------------------
	 *  Border radius
	 *  ボーダー半径ね。
	 * ---------------------------------------------------------------- */
	out property <length> RadiusSM:  4px;
	out property <length> RadiusMD:  7px;
	out property <length> RadiusLG: 12px;
	out property <length> RadiusFull: 9999px;

	/* ------------------------------------------------------------------
	 *  Panel dimensions
	 *  パネルサイズね。
	 * ---------------------------------------------------------------- */
	out property <length> SidebarWidth:    280px;
	out property <length> InspectorWidth:  300px;
	out property <length> StatusBarHeight:  26px;
	out property <length> ToolbarHeight:    42px;
	out property <length> SliderHeight:     22px;
	out property <length> ButtonHeight:     32px;
	out property <length> InputHeight:      28px;

	/* ------------------------------------------------------------------
	 *  Animation durations (§3.34)
	 *  アニメーション時間ね。
	 * ---------------------------------------------------------------- */
	out property <duration> AnimFast:   100ms;
	out property <duration> AnimNormal: 200ms;
	out property <duration> AnimSlow:   350ms;
	out property <duration> ToastLife: 4000ms;
}

/* =========================================================================
 *  Reusable component: TpButton — styled button with hover + press states
 *  再利用可能なコンポーネント：スタイル付きボタンね。
 * ====================================================================== */
export component TpButton {
	in property <string>  Label;
	in property <bool>    Primary: false;
	in property <bool>    Danger:  false;
	in property <bool>    Enabled: true;
	in property <length>  MinWidth: 80px;
	callback Clicked();

	min-width: max(MinWidth, 80px);
	height: Tokens.ButtonHeight;

	Rectangle {
		x: 0; y: 0;
		width: parent.width;
		height: parent.height;
		border-radius: Tokens.RadiusMD;
		background:
			!root.Enabled        ? #ffffff18 :
			Touch.pressed        ? (root.Danger ? #C0202080 : Tokens.AccentPressed) :
			Touch.has-hover      ? (root.Danger ? #E0303088 : Tokens.AccentHover)   :
			root.Primary         ? Tokens.AccentPrimary :
			root.Danger          ? #E0303060                                         :
			                       Tokens.SurfaceElevated;

		border-color: root.Primary ? transparent : Tokens.SurfaceBorder;
		border-width: root.Primary ? 0px : 1px;

		animate background { duration: Tokens.AnimFast; easing: ease; }

		Text {
			text: root.Label;
			color: root.Enabled ? Tokens.TextPrimary : Tokens.TextMuted;
			font-size: Tokens.FontSizeBody;
			horizontal-alignment: center;
			vertical-alignment: center;
			width: parent.width;
			height: parent.height;
		}
	}

	Touch := TouchArea {
		enabled: root.Enabled;
		clicked => { root.Clicked(); }
	}
}

/* =========================================================================
 *  TpSlider — labelled horizontal slider
 *  ラベル付き水平スライダーね。
 * ====================================================================== */
export component TpSlider {
	in property <string>  Label;
	in property <float>   Value;
	in property <float>   Minimum: 0.0;
	in property <float>   Maximum: 1.0;
	in property <string>  Unit: "";
	in property <int>     Decimals: 2;
	out property <float>  CurrentValue: Value;
	callback Changed(float);

	height: Tokens.SliderHeight + 18px;

	VerticalLayout {
		padding: 0px;
		spacing: Tokens.SpaceXS;

		HorizontalLayout {
			padding: 0px;
			Text {
				text: root.Label;
				color: Tokens.TextSecondary;
				font-size: Tokens.FontSizeSmall;
				vertical-alignment: center;
			}
			Rectangle { horizontal-stretch: 1; }
			Text {
				text: root.Unit;
				color: Tokens.TextMuted;
				font-size: Tokens.FontSizeTiny;
				vertical-alignment: center;
			}
		}

		Rectangle {
			height: Tokens.SliderHeight;
			background: Tokens.SurfaceSecondary;
			border-radius: Tokens.RadiusFull;
			clip: true;

			/* Filled portion */
			Rectangle {
				x: 0;
				y: 0;
				height: parent.height;
				width: max(0px, (root.Value - root.Minimum) / max(0.0001, root.Maximum - root.Minimum) * parent.width);
				background: Tokens.AccentPrimary;
				border-radius: Tokens.RadiusFull;
				animate width { duration: Tokens.AnimFast; easing: ease; }
			}

			/* Thumb */
			Rectangle {
				x: max(0px, (root.Value - root.Minimum) / max(0.0001, root.Maximum - root.Minimum) * parent.width - 8px);
				y: (parent.height - 16px) / 2;
				width: 16px;
				height: 16px;
				border-radius: 8px;
				background: Tokens.AccentPrimary;
				drop-shadow-blur: 4px;
				drop-shadow-color: #00000060;
			}

			SliderTouch := TouchArea {
				pointer-event(e) => {
					if (e.button == PointerEventButton.left && e.kind == PointerEventKind.move) {
						root.CurrentValue = root.Minimum +
							clamp(e.position.x / self.width, 0.0, 1.0) * (root.Maximum - root.Minimum);
						root.Changed(root.CurrentValue);
					}
				}
				clicked => {
					root.CurrentValue = root.Minimum +
						clamp(self.mouse-x / self.width, 0.0, 1.0) * (root.Maximum - root.Minimum);
					root.Changed(root.CurrentValue);
				}
			}
		}
	}
}

/* =========================================================================
 *  TpToggle — labelled on/off toggle switch
 *  ラベル付きトグルスイッチね。
 * ====================================================================== */
export component TpToggle {
	in-out property <bool>   Active: false;
	in     property <string> Label;
	callback Toggled(bool);

	height: 22px;

	HorizontalLayout {
		padding: 0px;
		spacing: Tokens.SpaceMD;

		Text {
			text: root.Label;
			color: Tokens.TextSecondary;
			font-size: Tokens.FontSizeBody;
			vertical-alignment: center;
		}

		Rectangle { horizontal-stretch: 1; }

		/* Track */
		Rectangle {
			width: 38px;
			height: 22px;
			border-radius: 11px;
			background: root.Active ? Tokens.AccentPrimary : Tokens.SurfaceTertiary;
			animate background { duration: Tokens.AnimNormal; easing: ease; }

			/* Thumb */
			Rectangle {
				x: root.Active ? 18px : 2px;
				y: 2px;
				width: 18px;
				height: 18px;
				border-radius: 9px;
				background: Tokens.TextPrimary;
				drop-shadow-blur: 3px;
				drop-shadow-color: #00000040;
				animate x { duration: Tokens.AnimNormal; easing: ease; }
			}

			TouchArea {
				clicked => {
					root.Active = !root.Active;
					root.Toggled(root.Active);
				}
			}
		}
	}
}

/* =========================================================================
 *  TpSectionHeader — collapsible panel section header
 *  折り畳み可能なパネルセクションヘッダーね。
 * ====================================================================== */
export component TpSectionHeader {
	in-out property <bool>   Expanded: true;
	in     property <string> Title;
	callback ToggleExpanded();

	height: 30px;
	background: transparent;

	HorizontalLayout {
		padding-left: Tokens.SpaceMD;
		padding-right: Tokens.SpaceSM;
		spacing: Tokens.SpaceSM;

		Text {
			text: root.Expanded ? "▾" : "▸";
			color: Tokens.AccentPrimary;
			font-size: Tokens.FontSizeBody;
			vertical-alignment: center;
		}

		Text {
			text: root.Title;
			color: Tokens.TextPrimary;
			font-size: Tokens.FontSizeMedium;
			font-weight: 600;
			vertical-alignment: center;
			horizontal-stretch: 1;
		}
	}

	Rectangle {
		y: parent.height - 1px;
		height: 1px;
		width: parent.width;
		background: Tokens.SurfaceBorder;
	}

	TouchArea {
		clicked => {
			root.Expanded = !root.Expanded;
			root.ToggleExpanded();
		}
	}
}

/* =========================================================================
 *  TpNumericField — single-line numeric input
 *  単行数値入力フィールドね。
 * ====================================================================== */
export component TpNumericField {
	in property <string> Label;
	in property <string> Value: "0.000";
	in property <string> Unit: "";
	callback Edited(string);

	height: Tokens.InputHeight + 18px;

	VerticalLayout {
		padding: 0px;
		spacing: Tokens.SpaceXS;

		HorizontalLayout {
			Text {
				text: root.Label;
				color: Tokens.TextSecondary;
				font-size: Tokens.FontSizeSmall;
				vertical-alignment: center;
			}
			Rectangle { horizontal-stretch: 1; }
			if root.Unit != "" : Text {
				text: root.Unit;
				color: Tokens.TextMuted;
				font-size: Tokens.FontSizeTiny;
				vertical-alignment: center;
			}
		}

		Rectangle {
			height: Tokens.InputHeight;
			background: Tokens.SurfaceSecondary;
			border-radius: Tokens.RadiusSM;
			border-color: Input.has-focus ? Tokens.AccentPrimary : Tokens.SurfaceBorder;
			border-width: 1px;
			animate border-color { duration: Tokens.AnimFast; easing: ease; }

			Input := LineEdit {
				x: Tokens.SpaceSM;
				y: 0;
				width: parent.width - 2 * Tokens.SpaceSM;
				height: parent.height;
				text: root.Value;
				font-size: Tokens.FontSizeBody;
				color: Tokens.TextPrimary;
				selection-background-color: Tokens.AccentSubtle;
				selection-foreground-color: Tokens.TextPrimary;
				edited(V) => { root.Edited(V); }
			}
		}
	}
}

/* =========================================================================
 *  TpBadge — coloured category badge
 *  カラーカテゴリーバッジね。
 * ====================================================================== */
export component TpBadge {
	in property <string> Label;
	in property <color>  BadgeColor: Tokens.AccentPrimary;

	height: 18px;

	Rectangle {
		background: root.BadgeColor.with-alpha(0.2);
		border-color: root.BadgeColor.with-alpha(0.6);
		border-width: 1px;
		border-radius: Tokens.RadiusFull;
		padding-left: Tokens.SpaceSM;
		padding-right: Tokens.SpaceSM;

		Text {
			text: root.Label;
			color: root.BadgeColor;
			font-size: Tokens.FontSizeTiny;
			vertical-alignment: center;
			horizontal-alignment: center;
		}
	}
}
